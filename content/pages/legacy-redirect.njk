---
pagination:
  data: legacyRedirects.redirects
  size: 1
  alias: legacyRedirect
permalink: "{{ legacyRedirect.from }}/index.html"
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <title>Redirection…</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href="{{ metadata.url }}{{ legacyRedirect.to | url }}" />
  <meta http-equiv="refresh" content="0;url={{ legacyRedirect.to | url }}" />
  <script>location.replace('{{ legacyRedirect.to | url }}');</script>
</head>
<body>
  <p>La page a déménagé. Si vous n’êtes pas redirigé, <a href="{{ legacyRedirect.to | url }}">suivez ce lien</a>.</p>
</body>
</html>
