---
layout: layouts/base.njk
---
{% set t = i18n[lang] %}
{% set p = localePathPrefix | default('') %}
{% set contactHomeHref = ('/contact/?sujet=' ~ (t.contactSujetGeneral | encodeURIComponent)) | localeUrl(p) | url %}
<section class="hero relative flex min-h-[92vh] items-end overflow-hidden bg-primary-dark pb-24 pt-32 text-white md:items-center md:pb-32">
  <div class="absolute inset-0 z-0">
    <img src="{{ '/images/arcimpact/headers/DSC_0083_v.jpg' | arcImage | url }}" alt="" class="h-full w-full object-cover opacity-50" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-t from-primary-dark via-primary-dark/70 to-primary/40"></div>
  </div>
  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 lg:px-8">
    <p class="mb-3 text-sm font-medium uppercase tracking-widest text-accent">{{ t.hero.kicker }}</p>
    <h1 class="mb-6 max-w-3xl font-serif text-4xl font-semibold leading-tight md:text-5xl lg:text-6xl">{{ t.hero.title }}</h1>
    <p class="mb-10 max-w-2xl text-lg text-white/90 md:text-xl">{{ t.hero.subtitle }}</p>
    <div class="flex flex-wrap gap-4">
      <a href="{{ '/stages/' | localeUrl(p) | url }}" class="inline-flex items-center justify-center rounded bg-white px-6 py-3 text-sm font-semibold text-primary shadow transition hover:bg-gray-100">{{ t.hero.ctaStages }}</a>
      <a href="{{ contactHomeHref }}" class="inline-flex items-center justify-center rounded border-2 border-white/70 px-6 py-3 text-sm font-semibold text-white transition hover:border-white hover:bg-white/10">{{ t.hero.ctaContact }}</a>
    </div>
  </div>
  <div class="scroll-indicator absolute bottom-8 left-1/2 hidden -translate-x-1/2 md:block" aria-hidden="true"></div>
</section>

{% if posters and posters.slides and (posters.slides | length) > 0 %}
<section id="affiches" class="border-t border-white/10 bg-charcoal py-16 text-white lg:py-20" aria-labelledby="affiches-title">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <h2 id="affiches-title" class="mb-2 text-center font-serif text-2xl font-semibold text-accent md:text-3xl">{{ t.postersTitle }}</h2>
    <p class="mx-auto mb-10 max-w-2xl text-center text-sm text-white/80 md:text-base">{{ t.postersLead }}</p>
    <div class="banner-carousel poster-marquee" role="region" aria-roledescription="carousel" aria-label="{{ t.postersTitle }}">
      <div class="banner-carousel-track poster-marquee-track">
        {% for slide in posters.slides %}
        <div class="banner-item poster-marquee-item">
          <a href="{{ ('/stages/' ~ slide.slug ~ '/') | localeUrl(p) | url }}" class="block overflow-hidden rounded-xl bg-white/5 no-underline ring-1 ring-white/10 transition hover:ring-accent">
            <img src="{{ slide.image | arcImage | url }}" alt="{{ slide.alt[lang] | default(slide.alt.fr) }}" class="h-full w-full object-cover object-top" loading="lazy" width="280" height="397" />
          </a>
        </div>
        {% endfor %}
        {% for slide in posters.slides %}
        <div class="banner-item poster-marquee-item" aria-hidden="true">
          <a href="{{ ('/stages/' ~ slide.slug ~ '/') | localeUrl(p) | url }}" class="block overflow-hidden rounded-xl bg-white/5 no-underline ring-1 ring-white/10 transition hover:ring-accent" tabindex="-1">
            <img src="{{ slide.image | arcImage | url }}" alt="" loading="lazy" width="280" height="397" />
          </a>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% endif %}

<section id="intro" class="py-16 lg:py-24">
  <div class="mx-auto grid max-w-7xl gap-12 px-4 lg:grid-cols-2 lg:items-center lg:px-8">
    <div data-animate="fade-up" class="transition duration-700">
      <img src="{{ '/images/arcimpact/headers/DSC_0169_v.jpg' | arcImage | url }}" alt="{{ t.intro.title }}" class="rounded-2xl shadow-xl" loading="lazy" width="640" height="420" />
    </div>
    <div data-animate="fade-up" class="transition delay-75 duration-700">
      <h2 class="mb-4 font-serif text-3xl font-semibold text-primary md:text-4xl">{{ t.intro.title }}</h2>
      <p class="mb-4 text-gray-600">{{ t.intro.p1 }}</p>
      <p class="text-gray-600">{{ t.intro.p2 }}</p>
      <a href="{{ '/emmanuel-lecuyer/' | localeUrl(p) | url }}" class="mt-6 inline-flex font-semibold text-primary-light hover:text-accent">{{ t.nav.emmanuel }} →</a>
    </div>
  </div>
</section>

<section id="video-accueil" class="border-t border-gray-100 bg-white py-16 lg:py-24" aria-labelledby="video-accueil-title">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 lg:grid-cols-2 lg:items-center lg:gap-14 lg:px-8">
    <div data-animate="fade-up" class="order-2 transition duration-700 lg:order-1">
      <p class="mb-2 text-sm font-medium uppercase tracking-widest text-primary-light">{{ t.homeVideoKicker }}</p>
      <h2 id="video-accueil-title" class="mb-4 font-serif text-3xl font-semibold text-primary md:text-4xl">{{ t.homeVideoTitle }}</h2>
      <p class="mb-6 text-gray-600">{{ t.homeVideoLead }}</p>
      <a href="{{ '/video-training/' | localeUrl(p) | url }}" class="inline-flex font-semibold text-primary-light hover:text-accent">{{ t.homeVideoCta }} →</a>
    </div>
    <div data-animate="fade-up" class="order-1 transition delay-75 duration-700 lg:order-2">
      <div class="relative aspect-video w-full overflow-hidden rounded-2xl bg-primary-dark shadow-xl ring-1 ring-gray-200">
        <iframe class="absolute inset-0 h-full w-full" src="https://www.youtube-nocookie.com/embed/UbmVWZKgqSY" title="{{ t.homeVideoIframeTitle }}" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </div>
    </div>
  </div>
</section>

<section id="piliers" class="border-y border-gray-100 bg-[#F5F5F0] py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      {% for pillar in t.pillars %}
      <div data-animate="fade-up" class="rounded-2xl bg-white p-8 shadow-sm transition duration-700">
        <h3 class="mb-3 font-serif text-xl font-semibold text-primary">{{ pillar.title }}</h3>
        <p class="text-gray-600">{{ pillar.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section id="stats" class="bg-primary py-16 text-white lg:py-20">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:grid-cols-2 lg:grid-cols-4 lg:px-8">
    {% for s in t.stats %}
    <div class="text-center">
      <p class="font-serif text-4xl font-bold text-accent md:text-5xl"><span data-counter="{{ s.n }}">{{ s.n }}</span>{{ s.s }}</p>
      <p class="mt-2 text-sm text-white/80">{{ s.l }}</p>
    </div>
    {% endfor %}
  </div>
</section>

<section id="stages" class="py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <h2 class="mb-3 text-center font-serif text-3xl font-semibold text-primary md:text-4xl">{{ t.servicesTitle }}</h2>
    <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">{{ t.servicesLead }}</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {% for item in services.items %}
      {% set s = item[lang] %}
      <a href="{{ ('/stages/' ~ item.slug ~ '/') | localeUrl(p) | url }}" class="group block overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md">
        <img src="{{ item.img | arcImage | url }}" alt="" class="h-40 w-full object-cover transition group-hover:scale-105" loading="lazy" width="400" height="160" />
        <div class="p-5">
          <h3 class="font-semibold text-primary group-hover:text-primary-light">{{ s.title }}</h3>
          <p class="mt-2 text-sm text-gray-600">{{ s.desc }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section id="palmarès" class="bg-charcoal py-16 text-white lg:py-20">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <h2 class="mb-10 text-center font-serif text-3xl font-semibold text-accent md:text-4xl">{{ t.palmarèsTitle }}</h2>
    <div class="mx-auto max-w-3xl space-y-6">
      {% for row in palmares.rows %}
      <div class="border-l-4 border-accent pl-6">
        <p class="text-sm font-semibold text-accent">{{ row.period }}</p>
        <p class="mt-1 text-white/85">{{ row[lang] }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{% include "partials/testimonials-section.njk" %}

<section class="bg-primary py-14 text-center text-white">
  <h2 class="mb-6 font-serif text-2xl font-semibold md:text-3xl">{{ t.ctaBand }}</h2>
  <a href="{{ contactHomeHref }}" class="inline-flex rounded bg-white px-8 py-3 font-semibold text-primary shadow transition hover:bg-gray-100">{{ t.ctaBandBtn }}</a>
</section>
