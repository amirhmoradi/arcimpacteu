---
layout: layouts/base.njk
---
{% set t = i18n[lang] %}
{% set p = localePathPrefix | default('') %}
{% if heroImage %}
<section class="relative overflow-hidden bg-primary-dark py-16 text-white md:py-20">
  <div class="absolute inset-0">
    <img src="{{ heroImage | arcImage | url }}" alt="" class="h-full w-full object-cover opacity-40" loading="eager" width="1600" height="600" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark via-primary-dark/90 to-primary-dark/60"></div>
  </div>
  <div class="relative z-10 mx-auto max-w-4xl px-4 lg:px-8">
    {% if heroKicker %}<p class="mb-2 text-sm font-medium uppercase tracking-widest text-accent">{{ heroKicker }}</p>{% endif %}
    <h1 class="font-serif text-3xl font-semibold leading-tight md:text-4xl lg:text-5xl">{{ title }}</h1>
    {% if description %}<p class="mt-4 max-w-2xl text-lg text-white/90">{{ description }}</p>{% endif %}
  </div>
</section>
{% endif %}
{% set _showPoster = showPosterSheet | default(false) %}
{% if heroImage and _showPoster %}
<section class="border-b border-gray-200 bg-[#e8e6df] py-10 md:py-14" aria-labelledby="poster-sheet-heading">
  <div class="mx-auto max-w-5xl px-4 lg:px-8">
    <div class="text-center">
      <h2 id="poster-sheet-heading" class="font-serif text-xl font-semibold text-primary md:text-2xl">{{ t.posterSheetTitle }}</h2>
      <p class="mx-auto mt-2 max-w-2xl text-sm text-gray-600 md:text-base">{{ t.posterSheetLead }}</p>
    </div>
    <figure class="mt-8 overflow-hidden rounded-2xl border border-gray-200 bg-white p-3 shadow-xl md:p-6">
      <img src="{{ heroImage | arcImage | url }}" alt="{{ posterAlt | default(title) }}" class="mx-auto max-h-[min(92vh,960px)] w-full max-w-3xl object-contain object-top" width="800" height="1132" loading="lazy" decoding="async" />
      <figcaption class="mt-4 border-t border-gray-100 pt-4 text-left text-sm text-gray-600">{{ t.posterSheetCaption }}</figcaption>
    </figure>
  </div>
</section>
{% endif %}
<section class="bg-[#F5F5F0] pb-20 {% if heroImage %}pt-10{% else %}pt-8{% endif %}">
  <div class="prose-wrap mx-auto max-w-4xl px-4 text-charcoal lg:px-8">
    <div class="article-markdown text-base leading-relaxed [&_h1]:mb-4 [&_h1]:font-serif [&_h1]:text-3xl [&_h1]:font-semibold [&_h1]:text-primary [&_h2]:mt-10 [&_h2]:scroll-mt-28 [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:text-primary [&_figure]:my-8 [&_img]:rounded-xl [&_img]:shadow-md [&_ul]:my-4 [&_li]:my-1 [&_a]:font-medium [&_a]:text-primary-light [&_a]:underline [&_.cta-row]:my-10 [&_.cta-row]:flex [&_.cta-row]:flex-wrap [&_.cta-row]:gap-4">
      {% if not heroImage %}
      <h1 class="mb-4 font-serif text-3xl font-semibold text-primary">{{ title }}</h1>
      {% endif %}
      {{ content | safe }}
    </div>
    {% if prefillContactSubject == false %}
    {% set ctaSujet = '' %}
    {% elif ctaContactSubject %}
    {% set ctaSujet = ctaContactSubject %}
    {% elif ctaSujet %}
    {# keep front-matter ctaSujet #}
    {% else %}
    {% set ctaSujet = title %}
    {% endif %}
    {% include "partials/cta-block.njk" %}
  </div>
</section>
