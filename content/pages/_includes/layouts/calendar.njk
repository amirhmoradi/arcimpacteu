---
layout: layouts/base.njk
---
{% set t = i18n[lang] %}
{% set p = localePathPrefix | default('') %}
{% set cal = calendar | default({}) %}
{% set heroKicker = t.calendarKicker %}
{% include "partials/page-hero-header.njk" %}
<section class="bg-[#F5F5F0] py-12">
  <div class="mx-auto max-w-5xl px-4 lg:px-8">
    <div class="prose-wrap mx-auto mb-8 max-w-3xl text-charcoal">
      <div class="article-markdown text-base leading-relaxed [&_a]:font-medium [&_a]:text-primary-light [&_a]:underline">{{ content | safe }}</div>
    </div>
    <div class="mx-auto mb-10 max-w-3xl rounded-2xl border border-accent/40 bg-gradient-to-br from-primary/5 to-white p-6 shadow-sm md:p-8">
      <p class="font-serif text-lg font-semibold text-primary md:text-xl">{{ t.calendarUrgencyTitle }}</p>
      <p class="mt-3 text-sm leading-relaxed text-gray-700 md:text-base">{{ t.calendarUrgencyLead }}</p>
      <a href="{{ ('/contact/?sujet=' ~ (t.calendarContactSujet | encodeURIComponent)) | localeUrl(p) | url }}" class="mt-5 inline-flex rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white no-underline shadow transition hover:bg-primary-light">{{ t.calendarUrgencyCta }}</a>
    </div>
    {% if cal.embedUrl %}
    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-md">
      <iframe title="{{ t.calendarIframeTitle }}" src="{{ cal.embedUrl }}" class="h-[720px] w-full border-0" loading="lazy"></iframe>
    </div>
    {% else %}
    <p class="rounded-xl border border-amber-200 bg-amber-50 p-6 text-center text-amber-900">{{ t.calendarPlaceholder }}</p>
    {% endif %}
    <div class="mt-8 flex flex-wrap justify-center gap-4 text-center">
      {% if cal.publicCalendarUrl %}
      <a href="{{ cal.publicCalendarUrl }}" class="inline-flex rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white no-underline hover:bg-primary-light" rel="noopener noreferrer">{{ t.calendarOpenGoogle }}</a>
      {% endif %}
      {% if cal.icsUrl %}
      <a href="{{ cal.icsUrl }}" class="inline-flex rounded-lg border-2 border-primary px-6 py-3 text-sm font-semibold text-primary no-underline hover:bg-primary/5">{{ t.calendarAddIcs }}</a>
      {% endif %}
    </div>
    {% set ctaTitle = t.calendarCtaTitle %}
    {% set ctaLead = t.calendarCtaLead %}
    {% set ctaPrimaryLabel = t.calendarCtaPrimary %}
    {% set ctaSujet = t.calendarContactSujet %}
    {% set ctaSecondaryLabel = t.nav.evenements %}
    {% set ctaSecondaryHref = '/evenements/' %}
    <div class="mx-auto mt-12 max-w-4xl">
      {% include "partials/cta-block.njk" %}
    </div>
  </div>
</section>
