{# Same card pattern as événements hub: thumbnail on top, badge, title, excerpt, CTA. #}
{% set p = localePathPrefix | default('') %}
{% set t = i18n[lang] %}
<div class="not-prose grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
  {% for item in services %}
  {% set s = item[lang] %}
  {% set badge = item.slug | replace("stage-", "") | replace("-", " ") | upper %}
  <article class="flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md">
    <a href="{{ ('/stages/' ~ item.slug ~ '/') | localeUrl(p) | url }}" class="block shrink-0">
      <img src="{{ item.img | arcImage | url }}" alt="" class="h-48 w-full object-cover" loading="lazy" width="600" height="320" />
    </a>
    <div class="flex flex-1 flex-col p-6">
      <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-accent">{{ badge }}</p>
      <h2 class="font-serif text-xl font-semibold text-primary">
        <a href="{{ ('/stages/' ~ item.slug ~ '/') | localeUrl(p) | url }}" class="text-inherit no-underline hover:text-primary-light">{{ s.title }}</a>
      </h2>
      <p class="mt-2 flex-1 text-sm text-gray-600">{{ s.desc }}</p>
      <a href="{{ ('/stages/' ~ item.slug ~ '/') | localeUrl(p) | url }}" class="mt-4 inline-flex font-semibold text-primary-light hover:text-accent">{{ t.stagesCardCta }} →</a>
    </div>
  </article>
  {% endfor %}
</div>
