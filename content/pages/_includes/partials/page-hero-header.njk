{# Shared dark header (Événements / Calendrier style). Expects: title, optional description, optional heroKicker. #}
<section class="bg-primary-dark py-14 text-white md:py-18">
  <div class="mx-auto max-w-4xl px-4 text-center lg:px-8">
    {% if heroKicker %}
    <p class="mb-2 text-sm font-medium uppercase tracking-widest text-accent">{{ heroKicker }}</p>
    {% endif %}
    <h1 class="font-serif text-3xl font-semibold md:text-4xl">{{ title }}</h1>
    {% if description %}<p class="mx-auto mt-4 max-w-2xl text-lg text-white/90">{{ description }}</p>{% endif %}
  </div>
</section>
