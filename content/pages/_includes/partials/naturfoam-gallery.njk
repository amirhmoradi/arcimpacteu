{# Local gallery under /images/arcimpact/naturefoam/ — filenames from _data/naturfoamGallery.json #}
{% set t = i18n[lang] %}
<div class="not-prose mt-10">
  <h2 class="mb-4 font-serif text-2xl font-semibold text-primary">{{ t.naturfoamGalleryTitle }}</h2>
  <p class="mb-6 max-w-3xl text-sm text-gray-600 md:text-base">{{ t.naturfoamGalleryLead }}</p>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
    {% for f in naturfoamGallery.files %}
    <a href="{{ ('/images/arcimpact/naturefoam/' ~ f) | url }}" class="group block overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm ring-1 ring-gray-100 transition hover:ring-accent" target="_blank" rel="noopener noreferrer">
      <img src="{{ ('/images/arcimpact/naturefoam/' ~ f) | url }}" alt="" class="aspect-square h-full w-full object-cover transition group-hover:scale-[1.03]" loading="lazy" width="300" height="300" />
    </a>
    {% endfor %}
  </div>
</div>
