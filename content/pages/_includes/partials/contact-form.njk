{% set t = ui[lang] %}
{% set p = localePathPrefix | default('') %}
<section class="bg-[#F5F5F0] pb-20 pt-8">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <h1 class="mb-3 font-serif text-4xl font-semibold text-primary">{{ t.contactTitle }}</h1>
    <p class="mb-10 max-w-2xl text-gray-600">{{ t.contactLead }}</p>
    <div class="grid gap-12 lg:grid-cols-2">
      <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
        <form id="contact-form" class="space-y-5" novalidate>
          <div class="form-hp absolute -left-[9999px] opacity-0" aria-hidden="true">
            <label>Ne pas remplir<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
          </div>
          <div class="form-group grid gap-4 sm:grid-cols-2">
            <div>
              <label class="mb-1 block text-sm font-medium text-gray-700" for="nom">{{ t.form.name }} *</label>
              <input class="w-full rounded-lg border border-gray-300 px-3 py-2" id="nom" name="nom" type="text" required autocomplete="family-name" />
            </div>
            <div>
              <label class="mb-1 block text-sm font-medium text-gray-700" for="prenom">{{ t.form.first }} *</label>
              <input class="w-full rounded-lg border border-gray-300 px-3 py-2" id="prenom" name="prenom" type="text" required autocomplete="given-name" />
            </div>
          </div>
          <div class="form-group">
            <label class="mb-1 block text-sm font-medium text-gray-700" for="club">{{ t.form.club }}</label>
            <input class="w-full rounded-lg border border-gray-300 px-3 py-2" id="club" name="club" type="text" autocomplete="organization" />
          </div>
          <div class="form-group">
            <label class="mb-1 block text-sm font-medium text-gray-700" for="email">{{ t.form.email }} *</label>
            <input class="w-full rounded-lg border border-gray-300 px-3 py-2" id="email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label class="mb-1 block text-sm font-medium text-gray-700" for="telephone">{{ t.form.phone }} *</label>
            <input class="w-full rounded-lg border border-gray-300 px-3 py-2" id="telephone" name="telephone" type="tel" required autocomplete="tel" />
          </div>
          <div class="form-group">
            <span class="mb-2 block text-sm font-medium text-gray-700">{{ t.form.newsletter }}</span>
            <div class="flex gap-4">
              <label class="inline-flex items-center gap-2"><input type="radio" name="newsletter" value="oui" /> {{ t.form.newsYes }}</label>
              <label class="inline-flex items-center gap-2"><input type="radio" name="newsletter" value="non" checked /> {{ t.form.newsNo }}</label>
            </div>
          </div>
          <div class="form-group">
            <label class="mb-1 block text-sm font-medium text-gray-700" for="message">{{ t.form.message }} *</label>
            <textarea class="w-full rounded-lg border border-gray-300 px-3 py-2" id="message" name="message" rows="5" required></textarea>
          </div>
          <div class="cf-turnstile" data-sitekey="{{ site.turnstileSiteKey }}"></div>
          <p class="form-success-message text-sm font-medium text-green-600" style="display:none">{{ t.form.success }}</p>
          <p class="form-error-message text-sm font-medium text-red-600" style="display:none">{{ t.form.error }}</p>
          <button type="submit" class="rounded-lg bg-primary px-8 py-3 font-semibold text-white transition hover:bg-primary-light">{{ t.form.submit }}</button>
        </form>
      </div>
      <div class="space-y-6 text-gray-700">
        <p><strong class="text-primary">La Féclaz</strong><br />400 Rue Centrale de la Féclaz, 73230 Les Déserts, Savoie</p>
        <p><strong class="text-primary">Siège</strong><br />Le Puiset, 12 chemin du four, 73800 Planaise</p>
        <p><a class="font-semibold text-primary-light hover:text-accent" href="__REDACTED__">__REDACTED__</a><br /><a class="text-primary-light hover:text-accent" href="__REDACTED__">__REDACTED__</a></p>
        <p class="text-sm text-gray-500">Chambéry · Lac du Bourget · massifs de Savoie</p>
      </div>
    </div>
  </div>
</section>
