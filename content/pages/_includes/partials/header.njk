{% set t = i18n[lang] %}
{% set p = localePathPrefix | default('') %}
<header class="site-header">
  <div class="mx-auto flex h-full max-w-7xl items-center justify-between px-4 lg:px-8">
    <a href="{{ '/' | localeUrl(p) | url }}" class="flex items-center gap-3 text-white no-underline">
      <img src="{{ brand.logoUrl }}" alt="{{ brand.name }}" width="140" height="48" class="h-10 w-auto drop-shadow-sm" loading="eager" />
      <span class="hidden font-semibold tracking-tight text-white sm:inline">{{ brand.name }}</span>
    </a>
    <nav class="hidden items-center gap-6 md:flex" aria-label="Main">
      <a class="nav-link text-sm font-medium" href="{{ '/' | localeUrl(p) | url }}">{{ t.nav.home }}</a>
      <a class="nav-link text-sm font-medium" href="{{ '/emmanuel-lecuyer/' | localeUrl(p) | url }}">{{ t.nav.emmanuel }}</a>
      <a class="nav-link text-sm font-medium" href="{{ '/stages/' | localeUrl(p) | url }}">{{ t.nav.stages }}</a>
      <a class="nav-link text-sm font-medium" href="{{ '/seminaires/' | localeUrl(p) | url }}">{{ t.nav.seminaires }}</a>
      <a class="nav-link text-sm font-medium" href="{{ '/collectivites/' | localeUrl(p) | url }}">{{ t.nav.collectivites }}</a>
      <a class="nav-link text-sm font-medium" href="{{ '/contact/' | localeUrl(p) | url }}">{{ t.nav.contact }}</a>
    </nav>
    <div class="hidden items-center gap-2 md:flex">
      <a class="rounded px-2 py-1 text-xs font-semibold {% if lang == 'fr' %}bg-accent text-primary{% else %}text-white/80 hover:text-accent{% endif %}" href="{{ '/' | url }}">FR</a>
      <a class="rounded px-2 py-1 text-xs font-semibold {% if lang == 'en' %}bg-accent text-primary{% else %}text-white/80 hover:text-accent{% endif %}" href="{{ '/en/' | url }}">EN</a>
      <a class="rounded px-2 py-1 text-xs font-semibold {% if lang == 'it' %}bg-accent text-primary{% else %}text-white/80 hover:text-accent{% endif %}" href="{{ '/it/' | url }}">IT</a>
    </div>
    <button type="button" class="hamburger relative z-[1001] flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu">
      <span class="block h-0.5 w-6 rounded bg-white transition-transform"></span>
      <span class="block h-0.5 w-6 rounded bg-white"></span>
      <span class="block h-0.5 w-6 rounded bg-white transition-transform"></span>
    </button>
  </div>
  <div class="mobile-menu-overlay" aria-hidden="true"></div>
  <div id="mobile-menu" class="mobile-menu">
    <nav class="flex flex-col gap-1 px-6 py-4" aria-label="Mobile">
      <a class="border-b border-white/10 py-3 text-white" href="{{ '/' | localeUrl(p) | url }}">{{ t.nav.home }}</a>
      <a class="border-b border-white/10 py-3 text-white" href="{{ '/emmanuel-lecuyer/' | localeUrl(p) | url }}">{{ t.nav.emmanuel }}</a>
      <a class="border-b border-white/10 py-3 text-white" href="{{ '/stages/' | localeUrl(p) | url }}">{{ t.nav.stages }}</a>
      <a class="border-b border-white/10 py-3 text-white" href="{{ '/seminaires/' | localeUrl(p) | url }}">{{ t.nav.seminaires }}</a>
      <a class="border-b border-white/10 py-3 text-white" href="{{ '/collectivites/' | localeUrl(p) | url }}">{{ t.nav.collectivites }}</a>
      <a class="border-b border-white/10 py-3 text-white" href="{{ '/contact/' | localeUrl(p) | url }}">{{ t.nav.contact }}</a>
      <div class="mt-4 flex gap-2">
        <a class="lang-btn flex-1 rounded bg-white/10 py-2 text-center text-sm text-white" href="{{ '/' | url }}" data-lang="fr">FR</a>
        <a class="lang-btn flex-1 rounded bg-white/10 py-2 text-center text-sm text-white" href="{{ '/en/' | url }}" data-lang="en">EN</a>
        <a class="lang-btn flex-1 rounded bg-white/10 py-2 text-center text-sm text-white" href="{{ '/it/' | url }}" data-lang="it">IT</a>
      </div>
    </nav>
  </div>
</header>
<div class="h-[var(--header-height)] shrink-0" aria-hidden="true"></div>
