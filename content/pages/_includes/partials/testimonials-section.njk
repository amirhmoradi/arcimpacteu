{% set t = i18n[lang] %}
{% set p = localePathPrefix | default('') %}
{% set reviewsHref = ('/contact/?sujet=' ~ (t.reviewsContactSujet | encodeURIComponent)) | localeUrl(p) | url %}
<section id="témoignages" class="border-t border-gray-100 bg-gradient-to-b from-white to-cream py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="mb-12 text-center">
      <div class="mx-auto mb-4 h-[2px] w-12 bg-accent"></div>
      <h2 class="mb-4 font-serif text-3xl font-semibold tracking-tight text-primary">{{ t.testimonialsTitle }}</h2>
      <p class="mx-auto max-w-xl text-sm text-gray-500">{{ t.testimonialsSectionLead }}</p>
    </div>

    {# Invite banner #}
    <div class="not-prose mx-auto mb-16 max-w-4xl overflow-hidden rounded-2xl border border-primary/10 bg-white shadow-lg">
      <div class="grid gap-0 md:grid-cols-5">
        <div class="relative flex min-h-[200px] flex-col justify-center overflow-hidden bg-primary-dark p-8 text-white md:col-span-2">
          <img src="{{ '/images/arcimpact/headers/DSC_0169_v.jpg' | arcImage | url }}" alt="" class="absolute inset-0 h-full w-full object-cover opacity-20" width="800" height="600" />
          <div class="relative z-10">
            <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.15em] text-accent">{{ t.reviewsInviteKicker }}</p>
            <p class="font-serif text-xl font-semibold leading-snug md:text-2xl">{{ t.reviewsInviteTitle }}</p>
            <p class="mt-3 text-sm leading-relaxed text-white/70">{{ t.reviewsInviteLead }}</p>
            <a href="{{ reviewsHref }}" class="mt-6 inline-flex rounded-md bg-white px-5 py-2.5 text-sm font-semibold text-primary no-underline shadow transition hover:-translate-y-0.5 hover:shadow-lg">{{ t.reviewsInviteCta }}</a>
          </div>
        </div>
        <div class="flex flex-col justify-center bg-cream p-8 md:col-span-3">
          <ul class="space-y-4 text-sm text-gray-600">
            <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>{{ t.reviewsStep1 }}</li>
            <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>{{ t.reviewsStep2 }}</li>
            <li class="flex gap-3"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>{{ t.reviewsStep3 }}</li>
          </ul>
        </div>
      </div>
    </div>

    {# Carousel #}
    {% if testimonials | length %}
    <div class="carousel relative">
      <div class="overflow-hidden rounded-2xl">
        <div class="carousel-track flex transition-transform duration-500 ease-out">
          {% for item in testimonials %}
          {% set Q = item.quote %}
          {% set quoteText = Q[lang] if Q and Q[lang] else (Q.fr if Q else '') %}
          {% set B = item.bow %}
          {% set bowLabel = B[lang] if B and B[lang] else (B.fr if B else '') %}
          <div class="carousel-slide w-full shrink-0 basis-full px-2 md:basis-1/2 lg:basis-1/3">
            <blockquote class="flex h-full min-h-[220px] flex-col rounded-2xl border border-gray-100 bg-white p-7 shadow-sm transition hover:border-accent/20 hover:shadow-md md:min-h-[260px] md:p-8">
              <div class="mb-5 flex items-start gap-4">
                {% if item.image %}
                <img src="{{ item.image | arcImage | url }}" alt="" class="h-14 w-14 shrink-0 rounded-full object-cover ring-2 ring-accent/30" width="56" height="56" loading="lazy" />
                {% else %}
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-primary-dark to-primary ring-2 ring-accent/20" aria-hidden="true"><span class="font-serif text-2xl leading-none text-accent">&ldquo;</span></div>
                {% endif %}
                <div class="min-w-0 flex-1">
                  <p class="font-serif text-lg leading-relaxed text-gray-700 md:text-xl">&ldquo;{{ quoteText }}&rdquo;</p>
                </div>
              </div>
              <footer class="mt-auto border-t border-gray-50 pt-4 text-sm">
                <span class="font-semibold text-primary">{{ item.who }}</span>
                {% if bowLabel %}<span class="text-gray-400"> · {{ bowLabel }}</span>{% endif %}
              </footer>
            </blockquote>
          </div>
          {% endfor %}
        </div>
      </div>
      <button type="button" class="carousel-btn-prev absolute left-0 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-white p-2 shadow md:block" aria-label="Previous">&lsaquo;</button>
      <button type="button" class="carousel-btn-next absolute right-0 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-white p-2 shadow md:block" aria-label="Next">&rsaquo;</button>
      <div class="carousel-dots mt-8 flex justify-center gap-2"></div>
    </div>
    {% else %}
    <p class="mx-auto max-w-xl text-center text-gray-500">{{ t.testimonialsEmpty }}</p>
    {% endif %}
  </div>
</section>
