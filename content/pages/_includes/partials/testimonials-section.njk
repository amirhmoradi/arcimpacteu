{% set t = i18n[lang] %}
{% set p = localePathPrefix | default('') %}
{% set reviewsHref = ('/contact/?sujet=' ~ (t.reviewsContactSujet | encodeURIComponent)) | localeUrl(p) | url %}
<section id="témoignages" class="border-t border-gray-100 bg-gradient-to-b from-white to-[#F5F5F0] py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <h2 class="mb-4 text-center font-serif text-3xl font-semibold text-primary">{{ t.testimonialsTitle }}</h2>
    <p class="mx-auto mb-10 max-w-2xl text-center text-sm text-gray-600 md:text-base">{{ t.testimonialsSectionLead }}</p>

    <div class="not-prose mx-auto mb-14 max-w-4xl overflow-hidden rounded-2xl border border-primary/15 bg-white shadow-lg ring-1 ring-primary/5">
      <div class="grid gap-0 md:grid-cols-5">
          <div class="relative flex min-h-[200px] flex-col justify-center overflow-hidden bg-primary-dark p-8 text-white md:col-span-2">
          <img src="{{ '/images/arcimpact/headers/DSC_0169_v.jpg' | arcImage | url }}" alt="" class="absolute inset-0 h-full w-full object-cover opacity-25" width="800" height="600" />
          <div class="relative z-10">
            <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent">{{ t.reviewsInviteKicker }}</p>
            <p class="font-serif text-xl font-semibold leading-snug md:text-2xl">{{ t.reviewsInviteTitle }}</p>
            <p class="mt-3 text-sm leading-relaxed text-white/90">{{ t.reviewsInviteLead }}</p>
            <a href="{{ reviewsHref }}" class="mt-6 inline-flex rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-primary no-underline shadow transition hover:bg-gray-100">{{ t.reviewsInviteCta }}</a>
          </div>
        </div>
        <div class="flex flex-col justify-center bg-[#F5F5F0] p-8 md:col-span-3">
          <ul class="space-y-3 text-sm text-gray-700">
            <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>{{ t.reviewsStep1 }}</li>
            <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>{{ t.reviewsStep2 }}</li>
            <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>{{ t.reviewsStep3 }}</li>
          </ul>
        </div>
      </div>
    </div>

    {% if testimonials | length %}
    <div class="carousel relative">
      <div class="overflow-hidden rounded-2xl">
        <div class="carousel-track flex transition-transform duration-500 ease-out">
          {% for item in testimonials %}
          {% set Q = item.quote %}
          {% set quoteText = Q[lang] if Q and Q[lang] else (Q.fr if Q else '') %}
          {% set B = item.bow %}
          {% set bowLabel = B[lang] if B and B[lang] else (B.fr if B else '') %}
          <div class="carousel-slide w-full shrink-0 basis-full px-2 md:basis-1/2 lg:basis-1/3">
            <blockquote class="testimonial-showcase-card flex h-full min-h-[220px] flex-col rounded-2xl border border-gray-200/80 bg-white p-6 shadow-md md:min-h-[260px] md:p-8">
              <div class="mb-5 flex items-start gap-4">
                {% if item.image %}
                <img src="{{ item.image | arcImage | url }}" alt="" class="h-16 w-16 shrink-0 rounded-full object-cover ring-2 ring-accent/40" width="64" height="64" loading="lazy" />
                {% else %}
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-primary to-primary-light ring-2 ring-accent/30" aria-hidden="true"><span class="font-serif text-3xl leading-none text-accent">“</span></div>
                {% endif %}
                <div class="min-w-0 flex-1">
                  <p class="font-serif text-lg leading-relaxed text-gray-800 md:text-xl">“{{ quoteText }}”</p>
                </div>
              </div>
              <footer class="mt-auto border-t border-gray-100 pt-4 text-sm">
                <span class="font-semibold text-primary">{{ item.who }}</span>
                {% if bowLabel %}<span class="text-gray-500"> · {{ bowLabel }}</span>{% endif %}
              </footer>
            </blockquote>
          </div>
          {% endfor %}
        </div>
      </div>
      <button type="button" class="carousel-btn-prev absolute left-0 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-white p-2 shadow md:block" aria-label="Previous">‹</button>
      <button type="button" class="carousel-btn-next absolute right-0 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-white p-2 shadow md:block" aria-label="Next">›</button>
      <div class="carousel-dots mt-8 flex justify-center gap-2"></div>
    </div>
    {% else %}
    <p class="mx-auto max-w-xl text-center text-gray-600">{{ t.testimonialsEmpty }}</p>
    {% endif %}
  </div>
</section>
